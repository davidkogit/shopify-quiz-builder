# RENAME THIS FILE TO: .env.example
# (File created as env.example to bypass env-file protection)
#
# ─── Shopify OAuth ───────────────────────────────────
# From Shopify Partners dashboard → Apps → App setup → API credentials
SHOPIFY_API_KEY=
# App secret — never commit to version control
SHOPIFY_API_SECRET=
# Your Netlify deployment URL (e.g. https://my-quiz-kit.netlify.app)
# Used for OAuth redirect URIs. Set before deploying.
SHOPIFY_APP_URL=
# Comma-separated OAuth access scopes requested from merchants
# Minimum: write_products,read_products,read_orders,write_orders
SCOPES="write_products,read_products,read_orders"

# ─── Session Encryption ─────────────────────────────
# Random 32+ character string. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ─── Database ────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or self-hosted).
# For local dev with SQLite, leave unset — Prisma defaults to SQLite.
DATABASE_URL=
